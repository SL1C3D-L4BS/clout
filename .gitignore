# ─────────────────────────────────────────────────────────────
# Clout — Unity .gitignore (AAA-grade)
# ─────────────────────────────────────────────────────────────

# Unity generated
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# IDE
.vs/
.vscode/
*.csproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db
.idea/

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Unity asset meta data
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Crashlytics
crashlytics-build.properties
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.app

# Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa.meta
/[Aa]ssets/[Ss]treaming[Aa]ssets/aa/*

# Plastic SCM
ignore.conf
*.private.0
*.private

# Secrets — never commit
*.env
*.env.local
*.env.*.local
credentials.json
secrets.json

# Large binary assets (use Git LFS instead)
# *.fbx
# *.wav
# *.mp3
# *.png
# *.jpg
# *.psd
